  // Edge-case: hvis logo er satt men INGEN av bildene har caption, vis logoen alene under
  // griden (gammel oppførsel) — så indikatoren ikke forsvinner helt.
  const hasAnyCaption = validImages.some(img => (img.cap || img.caption || '').trim());
  const logoHtml = (hasLogo && !hasAnyCaption) ? logoBadge : '';

  return `<!-- ============================================
