function buildEmbedSnippet() {
  const validImages = state.images.filter(img => isValidImageUrl(img.url));
  if (validImages.length === 0) return '';

  const id = 'fpu-' + Math.random().toString(36).slice(2, 8);
  const isGallery = state.mode === 'gallery' && validImages.length > 1;
  const credit = state.credit.trim();
  const creditHtml = credit ? `<span class="fpu-${id}-credit">Foto: ${escapeHtml(credit)}</span>` : '';

  // Bygg JSON-data som lightboxen kan lese
  const imgData = validImages.map(img => ({
    src: img.url,
    cap: (img.caption || '').trim(),
  }));
  const imgDataJson = JSON.stringify(imgData).replace(/</g, '\\u003c');

  // Logo-markup hentes ut én gang — brukes inline til venstre for caption hvis satt.
  const hasLogo = state.logo && state.logo !== 'none';
  const logoBadge = hasLogo
    ? `<div class="fpu-${id}-logo" role="img" aria-label="${escapeHtml(LOGO_LABELS[state.logo] || '')}">${logoSvg(state.logo)}</div>`
    : '';

  // Thumbnail + caption-rad per element. Caption-raden har logo til venstre (hvis satt),
  // tekst sentrert til høyre. Uten logo: tekst venstrejustert. I galleri-modus settes
  // logoen kun på FØRSTE caption — så fungerer den som delt kilde-indikator.
  const thumbsHtml = validImages.map((img, i) => {
    const cap = (img.cap || img.caption || '').trim();
    const showLogoHere = hasLogo && i === 0;
    // Bygg caption-rad
    let capRowHtml = '';
    if (cap || showLogoHere) {
      const capEl = cap
        ? `<figcaption class="fpu-${id}-cap${showLogoHere ? ' is-centered' : ''}">${escapeHtml(cap)}</figcaption>`
        : '';
      capRowHtml = `<div class="fpu-${id}-cap-row${showLogoHere ? ' has-logo' : ''}">${showLogoHere ? logoBadge : ''}${capEl}</div>`;
    }
    return `
    <div class="fpu-${id}-item">
      <button class="fpu-${id}-thumb" type="button" data-i="${i}" aria-label="Åpne bilde i pop-up">
        <img src="${escapeHtml(img.src || img.url)}" alt="${escapeHtml(cap)}" loading="lazy">
        <span class="fpu-${id}-thumb-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M15 3h6v6h-2V6.41l-4.29 4.3-1.42-1.42L17.59 5H15V3zM5 15H3v6h6v-2H6.41l4.3-4.29-1.42-1.42L5 17.59V15z"/></svg>
        </span>
