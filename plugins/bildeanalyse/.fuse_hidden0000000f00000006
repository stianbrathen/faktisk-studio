  // Labels — ligger UTENFOR cell-clip, på cellen direkte, så de aldri klippes.
  // Asymmetrisk plassering: A på TOP-HØYRE av rektangelet (venstre bilde), B på
  // TOP-VENSTRE (høyre bilde). Begge peker INNOVER mot connector-streken og
  // når aldri slidens ytterkanter — løser horisontal klipping uten padding-inline.
  // Visuelt leser det også naturlig: A → strek → B fra venstre til høyre.
  const labelsHtml = (marks, isLeft) => marks.map(m => {
